# ═══════════════════════════════════════════════════════════════════
# RTA AI Newsletter — Self-Hosted Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Run: cp .env.example .env

# ─── Database ───────────────────────────────────────────────────────
# MySQL connection string (required)
# Format: mysql://user:password@host:port/database
DATABASE_URL=

# ─── Authentication ─────────────────────────────────────────────────
# Secret key for signing JWT session tokens (required, use a random string)
JWT_SECRET=

# Local admin login credentials (used at /admin-login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=RTA@2026!

# Owner identity (used for admin role assignment)
OWNER_OPEN_ID=
OWNER_NAME=

# ─── Application ────────────────────────────────────────────────────
# App ID (can be any string for self-hosted, used internally)
VITE_APP_ID=

# Public site URL (used in PDF footer and metadata)
PUBLIC_SITE_URL=

# ─── OAuth (optional, not needed for self-hosted) ───────────────────
# These are only needed if you want to use external OAuth instead of
# the local admin login. Leave empty for local-only authentication.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# ─── Storage (optional) ────────────────────────────────────────────
# When these are empty, file uploads go to client/public/assets/uploads/
# Set these only if you want to use an external S3-compatible storage.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Frontend (optional) ───────────────────────────────────────────
# These are only needed for external API integrations.
# Leave empty for a fully self-contained deployment.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ─── Server ────────────────────────────────────────────────────────
# Port to run the server on (default: 3000)
PORT=3000

# Node environment (development or production)
NODE_ENV=development
